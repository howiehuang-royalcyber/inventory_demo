# Local secrets template for Streamlit. Copy to .streamlit/secrets.toml
# (gitignored). On Streamlit Community Cloud, paste the same contents into the
# app's "Secrets" panel — Streamlit Cloud injects them as environment variables
# automatically, so the rest of the code reads them via os.environ.

ANTHROPIC_API_KEY = "sk-ant-..."
# ANTHROPIC_MODEL = "claude-sonnet-4-6"
