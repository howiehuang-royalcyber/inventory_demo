# Copy this file to .env and fill in your key. .env is gitignored.
#
# Without ANTHROPIC_API_KEY, the demo falls back to a deterministic regex-based
# constraint extractor and a heuristic NL intent parser. Setting the key
# enables Claude for both, which materially improves the demo.

ANTHROPIC_API_KEY=sk-ant-...

# Optional. Default is claude-sonnet-4-6. Use claude-opus-4-7 for highest quality.
# ANTHROPIC_MODEL=claude-sonnet-4-6
